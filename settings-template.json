{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$REPO_DIR/play-sound.sh punch.wav"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$REPO_DIR/play-sound.sh heart-beat.mp3"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "$REPO_DIR/play-sound.sh vinyl-rewind.wav"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$REPO_DIR/play-sound.sh cash-register.mp3"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$REPO_DIR/play-sound.sh cinematic-boom.wav"
          }
        ]
      }
    ]
  }
}
